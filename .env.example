# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Security — set a random secret to protect API endpoints
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# UI access token — when set, users must visit /?token=YOUR_TOKEN to access the UI
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(16))"
UI_ACCESS_TOKEN=
ALLOWED_ORIGINS=*
RATE_LIMIT_PER_MINUTE=30
MAX_CHAT_MESSAGE_LENGTH=2000

# Server
PORT=8080
